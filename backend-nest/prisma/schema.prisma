generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

// ─── Table 1: modules ───────────────────────────────────────────────────────

model Module {
  id          String   @id @db.VarChar(50)
  name        String   @db.VarChar(255)
  slug        String   @unique @db.VarChar(100)
  description String?  @db.Text
  is_active   Boolean  @default(true) @map("is_active")
  created_at  DateTime @default(now()) @map("created_at")
  updated_at  DateTime @default(now()) @updatedAt @map("updated_at")

  questions ModuleQuestion[]
  imports   ModuleQuestionImport[]

  @@map("modules")
}

// ─── Table 2: module_questions ───────────────────────────────────────────────

enum Difficulty {
  easy
  medium
  hard
}

model ModuleQuestion {
  id           String     @id @db.VarChar(50)
  module_id    String     @map("module_id") @db.VarChar(50)
  slug         String     @db.VarChar(150)
  folder_name  String     @map("folder_name") @db.VarChar(100)
  title        String     @db.VarChar(500)
  difficulty   Difficulty @default(easy)
  topic        String     @default("General") @db.VarChar(255)
  tags         String?    @db.VarChar(500)
  question_py  String?    @map("question_py") @db.Text
  initial_code String?    @map("initial_code") @db.Text
  validator_py String?    @map("validator_py") @db.Text
  hint         String?    @db.Text
  sample_data  String?    @map("sample_data") @db.Text
  is_verified  Boolean    @default(false) @map("is_verified")
  is_active    Boolean    @default(true) @map("is_active")
  created_at   DateTime   @default(now()) @map("created_at")
  updated_at   DateTime   @default(now()) @updatedAt @map("updated_at")

  module Module @relation(fields: [module_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([module_id, slug], name: "uq_mq_module_slug")
  @@index([difficulty], map: "idx_mq_difficulty")
  @@index([topic], map: "idx_mq_topic")
  @@map("module_questions")
}

// ─── Table 3: module_question_imports ────────────────────────────────────────

enum ImportStatus {
  pending
  processing
  completed
  failed
}

model ModuleQuestionImport {
  id              Int          @id @default(autoincrement())
  module_id       String       @map("module_id") @db.VarChar(50)
  file_name       String       @map("file_name") @db.VarChar(255)
  file_path       String       @map("file_path") @db.VarChar(500)
  status          ImportStatus @default(pending)
  total_questions Int          @default(0) @map("total_questions")
  imported_count  Int          @default(0) @map("imported_count")
  failed_count    Int          @default(0) @map("failed_count")
  error_log       String?      @map("error_log") @db.Text
  imported_by     Int?         @map("imported_by")
  started_at      DateTime?    @map("started_at")
  completed_at    DateTime?    @map("completed_at")
  created_at      DateTime     @default(now()) @map("created_at")
  updated_at      DateTime     @default(now()) @updatedAt @map("updated_at")

  module Module @relation(fields: [module_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([module_id], map: "idx_qi_module_id")
  @@index([status], map: "idx_qi_status")
  @@map("module_question_imports")
}

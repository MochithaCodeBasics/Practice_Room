generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

// ─── Table 1: modules ───────────────────────────────────────────────────────

model Module {
  id          Int      @id @default(autoincrement()) @db.UnsignedInt
  name        String   @db.VarChar(255)
  slug        String   @unique @db.VarChar(100)
  description String?  @db.Text
  is_active   Boolean  @default(true) @map("is_active")
  created_at  DateTime @default(now()) @map("created_at")
  updated_at  DateTime @default(now()) @updatedAt @map("updated_at")

  questions ModuleQuestion[]
  imports   ModuleQuestionImport[]

  @@map("modules")
}

// ─── Table 2: module_questions ───────────────────────────────────────────────

enum Difficulty {
  easy
  medium
  hard
}

model ModuleQuestion {
  id           Int        @id @default(autoincrement()) @db.UnsignedInt
  module_id    Int        @map("module_id") @db.UnsignedInt
  slug         String     @db.VarChar(150)
  folder_name  String     @map("folder_name") @db.VarChar(100)
  title        String     @db.VarChar(500)
  difficulty   Difficulty @default(easy)
  topic        String     @default("General") @db.VarChar(255)
  tags         String?    @db.VarChar(500)
  question_py  String?    @map("question_py") @db.Text
  initial_code String?    @map("initial_code") @db.Text
  validator_py String?    @map("validator_py") @db.Text
  hint         String?    @db.Text
  sample_data  String?    @map("sample_data") @db.Text
  is_verified  Boolean    @default(false) @map("is_verified")
  is_active    Boolean    @default(true) @map("is_active")
  created_at   DateTime   @default(now()) @map("created_at")
  updated_at   DateTime   @default(now()) @updatedAt @map("updated_at")

  module Module @relation(fields: [module_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([module_id, slug], name: "uq_mq_module_slug")
  @@index([difficulty], map: "idx_mq_difficulty")
  @@index([topic], map: "idx_mq_topic")
  @@map("module_questions")
}

// ─── Table 3: module_question_imports ────────────────────────────────────────

enum ImportStatus {
  pending
  processing
  completed
  failed
}

model ModuleQuestionImport {
  id              Int          @id @default(autoincrement())
  module_id       Int          @map("module_id") @db.UnsignedInt
  file_name       String       @map("file_name") @db.VarChar(255)
  file_path       String       @map("file_path") @db.VarChar(500)
  status          ImportStatus @default(pending)
  total_questions Int          @default(0) @map("total_questions")
  imported_count  Int          @default(0) @map("imported_count")
  failed_count    Int          @default(0) @map("failed_count")
  error_log       String?      @map("error_log") @db.Text
  imported_by     Int?         @map("imported_by")
  started_at      DateTime?    @map("started_at")
  completed_at    DateTime?    @map("completed_at")
  created_at      DateTime     @default(now()) @map("created_at")
  updated_at      DateTime     @default(now()) @updatedAt @map("updated_at")

  module Module @relation(fields: [module_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([module_id], map: "idx_qi_module_id")
  @@index([status], map: "idx_qi_status")
  @@map("module_question_imports")
}

// ─── Table 4: users ─────────────────────────────────────────────────────────

model User {
  id              Int     @id @default(autoincrement())
  username        String  @unique @db.VarChar(50)
  email           String  @unique @db.VarChar(255)
  hashed_password String  @db.VarChar(255)
  role            String  @default("learner") @db.VarChar(20)
  disabled        Boolean @default(false)

  groq_api_key      String? @db.VarChar(255)
  openai_api_key    String? @db.VarChar(255)
  anthropic_api_key String? @db.VarChar(255)

  has_groq_api_key      Boolean @default(false)
  has_openai_api_key    Boolean @default(false)
  has_anthropic_api_key Boolean @default(false)

  default_llm_provider String @default("groq") @db.VarChar(20)

  current_streak    Int       @default(0) @map("current_streak")
  last_completed_at DateTime? @map("last_completed_at")

  created_at DateTime @default(now()) @map("created_at")
  updated_at DateTime @default(now()) @updatedAt @map("updated_at")

  progress     UserProgress[]
  reset_tokens PasswordResetToken[]
  submissions  UserSubmission[]

  @@map("users")
}

// ─── Table 5: user_progress ─────────────────────────────────────────────────

model UserProgress {
  id          Int      @id @default(autoincrement())
  username    String   @db.VarChar(50)
  question_id String   @map("question_id") @db.VarChar(50)
  status      String   @default("attempted") @db.VarChar(20)
  user_code   String?  @map("user_code") @db.Text
  created_at  DateTime @default(now()) @map("created_at")
  updated_at  DateTime @default(now()) @updatedAt @map("updated_at")

  user User @relation(fields: [username], references: [username], onDelete: Cascade)

  @@unique([username, question_id], name: "username_question_id")
  @@index([username], map: "idx_up_username")
  @@index([question_id], map: "idx_up_question_id")
  @@map("user_progress")
}

// ─── Table 6: user_submissions ───────────────────────────────────────────────

model UserSubmission {
  id             Int      @id @default(autoincrement())
  user_id        Int      @map("user_id")
  question_id    String   @map("question_id") @db.VarChar(50)
  submitted_code String?  @map("submitted_code") @db.Text
  stdout         String?  @db.Text
  stderr         String?  @db.Text
  status         String   @db.VarChar(10)
  created_at     DateTime @default(now()) @map("created_at")

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id], map: "idx_us_user_id")
  @@index([user_id, question_id], map: "idx_us_user_id_question")
  @@map("user_submissions")
}

// ─── Table 7: revoked_tokens ────────────────────────────────────────────────

model RevokedToken {
  jti        String   @id @db.VarChar(255)
  expires_at DateTime @map("expires_at")
  created_at DateTime @default(now()) @map("created_at")

  @@map("revoked_tokens")
}

// ─── Table 8: password_reset_tokens ─────────────────────────────────────────

model PasswordResetToken {
  id         Int      @id @default(autoincrement())
  user_id    Int      @map("user_id")
  token_hash String   @db.VarChar(255)
  used       Boolean  @default(false)
  expires_at DateTime @map("expires_at")
  created_at DateTime @default(now()) @map("created_at")

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([token_hash], map: "idx_prt_token_hash")
  @@map("password_reset_tokens")
}

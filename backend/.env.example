# Practice Room NestJS Backend - Environment Variables
# Copy this file to .env and update values

# Environment
ENVIRONMENT=development

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=practice_room

# JWT Authentication
# Generate with: openssl rand -base64 32
SECRET_KEY=
JWT_EXPIRATION_MINUTES=1440

# Default Admin Credentials
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=YourSecurePassword123!
DEFAULT_ADMIN_EMAIL=admin@yourdomain.com

# CORS - comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:3002

# Docker Execution (local sandboxed runner — disable when using Judge0)
USE_DOCKER_EXECUTOR=true
DOCKER_MEMORY_LIMIT=128m
DOCKER_CPU_LIMIT=0.5
DOCKER_TIMEOUT=30

# Judge0 Code Execution (external service — set USE_JUDGE0=true and point to your hosted instance)
USE_JUDGE0=false
JUDGE0_API_URL=
# API key — required if your Judge0 instance has AUTH_TOKEN set
JUDGE0_API_KEY=
# Optional: pin the Python language ID (auto-detected if left empty)
JUDGE0_PYTHON_LANGUAGE_ID=71

# Email Settings (for password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# Frontend URL (for password reset links)
FRONTEND_URL=http://localhost:3000

# Questions Directory (relative to project root or absolute)
QUESTIONS_DIR=../questions

# Server Port
PORT=3001

# Codebasics OAuth Config
CB_OAUTH_CLIENT_ID=
CB_OAUTH_CLIENT_SECRET=
CB_OAUTH_BASE_URL=https://beta.codebasics.io

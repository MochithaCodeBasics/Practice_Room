# Practice Room Frontend (Next.js) — Local Development Environment Variables
# Copy this file to .env.local and update values
# For Docker deployment, set these via .env.docker instead

# Auth.js Secret (generate with: openssl rand -base64 32)
AUTH_SECRET=

# Codebasics OAuth Credentials
# Obtain from your Codebasics developer panel (OAuth Clients section)
AUTH_CODEBASICS_ID=
AUTH_CODEBASICS_SECRET=

# Base URLs
CODEBASICS_BASE_URL=https://beta.codebasics.io
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Codebasics Image CDN prefix (used for profile avatars)
NEXT_PUBLIC_CB_IMAGE_PREFIX=https://beta-images.codebasics.io/filters:format(webp)/fit-in/50x50

# Backend API URL (local dev — in Docker this is set automatically to http://backend:3001)
BACKEND_URL=http://localhost:3001

# ── Practice Room — Docker Environment Variables ─────────────────────────────
# 1. Copy this file:  cp .env.docker.example .env.docker
# 2. Fill in the values below
# 3. Run:  docker compose --env-file .env.docker up --build
# 4. On server, lock permissions:  chmod 600 .env.docker

# ── Database (External — e.g. AWS RDS, PlanetScale, etc.) ────────────────────
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=practice_room

# ── Backend (NestJS) ─────────────────────────────────────────────────────────
ENVIRONMENT=production
SECRET_KEY=
JWT_EXPIRATION_MINUTES=1440

# Default Admin (created on first run via seed)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=
DEFAULT_ADMIN_EMAIL=

# ── Frontend (Next.js) ──────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=
AUTH_CODEBASICS_ID=
AUTH_CODEBASICS_SECRET=
CODEBASICS_BASE_URL=https://beta.codebasics.io
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CB_IMAGE_PREFIX=https://beta-images.codebasics.io/filters:format(webp)/fit-in/50x50
FRONTEND_URL=http://localhost:3000

# ── Codebasics OAuth ────────────────────────────────────────────────────────
CB_OAUTH_CLIENT_ID=
CB_OAUTH_CLIENT_SECRET=
CB_OAUTH_BASE_URL=https://beta.codebasics.io

# ── Email / SMTP (optional) ─────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
